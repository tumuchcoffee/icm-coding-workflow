# source/01-ui/.dockerignore
# Exclude files that are not needed in the Docker build context.
# This speeds up builds and reduces image size.

# Angular build output
dist/
.angular/

# Dependencies
node_modules/

# IDE
.idea/
.vscode/
*.sln

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile
.dockerignore
docker-compose*.yml

# Test files (not needed for production build)
*.spec.ts
karma.conf.js

# Documentation
README.md
docs/
